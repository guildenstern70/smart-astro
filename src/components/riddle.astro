---

<div id="dicegame" class="space-y-6">
    <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-wider text-indigo-600">The Challenge</p>
        <p class="text-lg text-gray-700 font-medium">I just thought of a number between 1 and 10.</p>
    </div>
    
    <form id="guessform" class="space-y-4">
        <div class="space-y-2">
            <label for="guessnumber" class="block text-sm font-medium text-gray-900">
                Your Guess
            </label>
            <input 
                type="number" 
                min="1" 
                max="10" 
                id="guessnumber"
                placeholder="Enter 1-10"
                class="block w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-indigo-500 focus:ring-indigo-500 bg-gray-50 text-gray-900 text-lg transition-all"
            />
        </div>
        <button 
            type="submit" 
            class="w-full px-6 py-3 bg-gray-900 text-white font-bold rounded-xl hover:bg-gray-800 transition-colors shadow-sm active:scale-95"
        >
            Check Guess
        </button>
    </form>
    
    <div id="hint" class="min-h-[3rem] flex items-center justify-center p-4 rounded-xl border border-transparent transition-all">
        <!-- Hint content will be injected here -->
    </div>
</div>

<style>
    /* Custom styles if needed beyond Tailwind */
    .spinner {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: conic-gradient(#0000 10%,#4f46e5);
        -webkit-mask: radial-gradient(farthest-side,#0000 calc(100% - 4px),#000 0);
        animation: spinner-zp9dbg 1s infinite linear;
    }

    @keyframes spinner-zp9dbg {
        to {
            transform: rotate(1turn);
        }
    }
</style>

<script src="./riddle.ts"></script>



